BOT_TOKEN=
ADMIN_USER_ID=

# LLM provider: "deepseek" or "openrouter"
LLM_PROVIDER=openrouter

DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-pro

OPENROUTER_API_KEY=
OPENROUTER_MODEL=qwen/qwen3.7-max  # google/gemini-3-flash

# OpenRouter model for audio transcription fallback (when no subtitles)
AUDIO_MODEL=google/gemini-2.5-flash

DB_PATH=database/bot.sqlite3

# Required for new users; leave empty to disable gate (local dev)
ACCESS_PASSWORD=

# Logs (optional)
LOG_DIR=logs
LOG_ROTATION=10 MB
LOG_RETENTION=14 days

# Sentry (optional — omit for local dev)
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
